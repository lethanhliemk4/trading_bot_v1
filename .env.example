#App
APP_MODE=prod
# APP_MODE=test
# APP_ENV=dev
APP_ENV=prod
APP_VERSION=1.0.0

# Scanner
SCANNER_MAX_SYMBOLS_PER_SCAN=80
SCANNER_RESULTS_LIMIT=5
SCANNER_MIN_QUOTE_VOLUME_5M=100000
SCANNER_MIN_PRICE_CHANGE_5M=1.2
SCANNER_MIN_VOLUME_SPIKE_RATIO=1.5

# Test / Paper mode
TEST_MODE_COOLDOWN_SECONDS=10

#telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
LIVE_ALLOWED_USER_IDS=

#Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=binance_bot
DB_USER=botuser
DB_PASSWORD=

MYSQL_ROOT_PASSWORD=

# AI
GEMINI_API_KEY=

# Risk - General / Paper
RISK_CAPITAL_USDT=10
RISK_PER_TRADE_PERCENT=2
MAX_OPEN_TRADES=1
DAILY_LOSS_LIMIT_USDT=2
MAX_NOTIONAL_PER_TRADE=10

# Global safety
ENABLE_LIVE_TRADING=true
KILL_SWITCH=false

# Binance - Live/Testnet execution
# =========================
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=false

# Explicit arming flags
LIVE_EXECUTION_ENABLED=true
LIVE_CONFIRM_REAL_ORDERS=true

# Exchange endpoints
BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443

BINANCE_TESTNET_REST_BASE_URL=https://testnet.binance.vision
BINANCE_TESTNET_WS_BASE_URL=wss://testnet.binance.vision/ws

# Network / request safety
BINANCE_RECV_WINDOW_MS=5000
BINANCE_HTTP_TIMEOUT_SECONDS=15

# =========================
# Live risk safety
# =========================
LIVE_MAX_NOTIONAL_PER_TRADE=5
LIVE_MAX_OPEN_TRADES=1
LIVE_DAILY_LOSS_LIMIT_USDT=2
LIVE_MIN_FREE_USDT=3

# Protection behavior
LIVE_PLACE_SL_TP_AFTER_ENTRY=true
LIVE_CANCEL_ENTRY_ON_PROTECTION_FAILURE=true


LIVE_MAX_TRADES_PER_DAY=5

LIVE_TRADE_COOLDOWN_SECONDS=600

LIVE_SYMBOL_COOLDOWN_SECONDS=3600

HEARTBEAT_INTERVAL_SECONDS=3600

WATCHDOG_INTERVAL_SECONDS=60
LOOP_STALE_THRESHOLD_SECONDS=600

LIVE_SYMBOL_COOLDOWN_AFTER_TP_SECONDS=3600
LIVE_SYMBOL_COOLDOWN_AFTER_SL_SECONDS=600
LIVE_SYMBOL_COOLDOWN_AFTER_OTHER_SECONDS=1800

# AI FILTER
ENABLE_AI_FILTER=false

STRATEGY_MIN_SCORE=65
STRATEGY_MIN_QUOTE_VOLUME_5M=150000
STRATEGY_MIN_VOLUME_SPIKE_RATIO=1.5
STRATEGY_MIN_ATR_RATIO=0.002
STRATEGY_SL_ATR_MULTIPLIER=1.5
STRATEGY_TP1_RR=1.2
STRATEGY_TP2_RR=2.0

ENABLE_SYMBOL_WHITELIST=false
WHITELIST_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,TRXUSDT

# Profit Guard
ENABLE_PROFIT_GUARD=true
MAX_LOSING_STREAK=3
MIN_WINRATE=0.4
MIN_MARKET_VOLATILITY=0.002

# Auto Stop
ENABLE_AUTO_STOP=true
AUTO_STOP_MAX_DAILY_LOSS=-5
AUTO_STOP_MIN_WINRATE=0.3
AUTO_STOP_MIN_TRADES=5

TZ=Asia/Ho_Chi_Minh